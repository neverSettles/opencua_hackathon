# Copy this file to .env and paste your real keys.
# .env is gitignored.

# Kernel browser (required for harness/run_t2_spike.py — drives the actual Chromium)
# Get from https://onkernel.com
KERNEL_API_KEY=

# Anthropic — for --model anthropic (Opus 4.7 / Sonnet 4.6 with computer-use beta)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — for --model openai (gpt-5.5 with computer-use)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tzafon / Lightcone — for --model northstar
# Get from https://lightcone.ai/developer
TZAFON_API_KEY=

# Google — for --model gemini
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# trajectories.sh upload token (for posting trajectories in harbor format)
TRAJECTORIES_SH_API_KEY=
