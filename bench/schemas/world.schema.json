  "properties": {
    "id": {"type": "string"},
    "persona": {"type": "string"},
    "version": {"type": "string"},
    "sellers": {"type": "array", "items": {"type": "string"}},
    "channels": {"type": "array", "items": {"type": "string"}},
    "evaluator": {"type": "string"}
  }
}
